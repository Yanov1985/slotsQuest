  themes                                themes?          @relation("DeprecatedTheme", fields: [theme_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([provider_id], map: "idx_slots_provider_id")
  @@index([category_id], map: "idx_slots_category_id")
  @@index([theme_id], map: "idx_slots_theme_id")
  @@index([is_active], map: "idx_slots_is_active")
  @@index([rating(sort: Desc)], map: "idx_slots_rating")
}

model slot_themes {
  id         String   @id @default(cuid())
  slot_id    String
  theme_id   String
  created_at DateTime @default(now())
  slots      slots    @relation(fields: [slot_id], references: [id], onDelete: Cascade)
  themes     themes   @relation(fields: [theme_id], references: [id], onDelete: Cascade)

  @@unique([slot_id, theme_id])
  @@index([slot_id], map: "idx_slot_themes_slot_id")
  @@index([theme_id], map: "idx_slot_themes_theme_id")
}

model features {
  id            Int             @id @default(autoincrement())
  name          String
  slug          String          @unique
  description   String?
  type          String?
  icon          String?
  color         String?         @default("#8b5cf6")
  image_url     String?
  sort_order    Int?            @default(0)
  is_active     Boolean         @default(true)
  is_popular    Boolean         @default(false)
  is_featured   Boolean         @default(false)
  created_at    DateTime        @default(now())
  updated_at    DateTime        @updatedAt
  slot_features slot_features[]

  @@index([type], map: "idx_features_type")
  @@index([is_active], map: "idx_features_is_active")
  @@index([is_popular], map: "idx_features_is_popular")
  @@index([sort_order], map: "idx_features_sort_order")
}

model slot_features {
  id         Int      @id @default(autoincrement())
  slot_id    String
  feature_id Int
  created_at DateTime @default(now())
  features   features @relation(fields: [feature_id], references: [id], onDelete: Cascade)
  slots      slots    @relation(fields: [slot_id], references: [id], onDelete: Cascade)

  @@unique([slot_id, feature_id])
  @@index([slot_id], map: "idx_slot_features_slot_id")
  @@index([feature_id], map: "idx_slot_features_feature_id")
}

model themes {
  id               String        @id @default(cuid())
  name             String        @unique
  slug             String        @unique
  description      String?
  color            String?
  icon             String?
  is_featured      Boolean       @default(false)
  is_active        Boolean       @default(true)
  created_at       DateTime      @default(now())
  updated_at       DateTime      @updatedAt
  slotThemes       slot_themes[]
  slots_deprecated slots[]       @relation("DeprecatedTheme")

  @@index([is_active])
  @@index([is_featured])
  @@index([slug])
}

model bonuses {
  id           Int            @id @default(autoincrement())
  name         String         @unique
  slug         String         @unique
  description  String?
  type         String?
  icon         String?
  color        String?        @default("#8b5cf6")
  image_url    String?
  sort_order   Int?           @default(0)
  is_active    Boolean        @default(true)
  is_popular   Boolean        @default(false)
  is_featured  Boolean        @default(false)
  created_at   DateTime       @default(now())
  updated_at   DateTime       @updatedAt
  slot_bonuses slot_bonuses[]

  @@index([type], map: "idx_bonuses_type")
  @@index([is_active], map: "idx_bonuses_is_active")
  @@index([is_popular], map: "idx_bonuses_is_popular")
  @@index([sort_order], map: "idx_bonuses_sort_order")
}

model slot_bonuses {
  id         Int      @id @default(autoincrement())
  slot_id    String
  bonus_id   Int
  created_at DateTime @default(now())
  bonuses    bonuses  @relation(fields: [bonus_id], references: [id], onDelete: Cascade)
  slots      slots    @relation(fields: [slot_id], references: [id], onDelete: Cascade)

  @@unique([slot_id, bonus_id])
  @@index([slot_id], map: "idx_slot_bonuses_slot_id")
  @@index([bonus_id], map: "idx_slot_bonuses_bonus_id")
}

model mechanics {
  id             Int              @id @default(autoincrement())
  name           String           @unique
  slug           String           @unique
  description    String?
  type           String?
  icon           String?
  color          String?          @default("#8b5cf6")
  image_url      String?
  sort_order     Int?             @default(0)
  is_active      Boolean          @default(true)
  is_popular     Boolean          @default(false)
  is_featured    Boolean          @default(false)
  created_at     DateTime         @default(now())
  updated_at     DateTime         @updatedAt
  slot_mechanics slot_mechanics[]

  @@index([type], map: "idx_mechanics_type")
  @@index([is_active], map: "idx_mechanics_is_active")
  @@index([is_popular], map: "idx_mechanics_is_popular")
  @@index([sort_order], map: "idx_mechanics_sort_order")
}

model slot_mechanics {
  id          Int       @id @default(autoincrement())
  slot_id     String
  mechanic_id Int
  created_at  DateTime  @default(now())
  mechanics   mechanics @relation(fields: [mechanic_id], references: [id], onDelete: Cascade)
  slots       slots     @relation(fields: [slot_id], references: [id], onDelete: Cascade)

  @@unique([slot_id, mechanic_id])
  @@index([slot_id], map: "idx_slot_mechanics_slot_id")
  @@index([mechanic_id], map: "idx_slot_mechanics_mechanic_id")
}

model pages {
  slug                     String   @id
  title                    String
  hero_title               String?
  hero_desc                String?
  seo_title                String?
  seo_desc                 String?
  seo_keywords             String?
  seo_canonical_url        String?
  seo_robots               String?
  hero_keyword_1           String?
  hero_keyword_2           String?
  hero_keyword_3           String?
  seo_keywords_primary     String?
  seo_keywords_lsi         String?
  seo_keywords_longtail    String?
  seo_keywords_geo         String?
  seo_keywords_list        String?
  robots_index             Boolean? @default(true)
  robots_follow            Boolean? @default(true)
  robots_max_snippet       Int?     @default(-1)
  robots_max_image_preview String?  @default("large")
  robots_max_video_preview Int?     @default(-1)
  robots_notranslate       Boolean? @default(false)
  robots_noimageindex      Boolean? @default(false)
  hreflang_enabled         Boolean? @default(false)
  hreflang_config          String?
  geo_target_enabled       Boolean? @default(false)
  geo_target_regions       String?
  jsonld_enabled           Boolean? @default(true)
  jsonld_type              String?  @default("CollectionPage")
  jsonld_enable_faq        Boolean? @default(false)
  jsonld_faq_json          String?
  jsonld_enable_review     Boolean? @default(false)
  jsonld_review_author     String?
  jsonld_review_rating     Decimal?
  jsonld_review_text       String?
  jsonld_enable_how_to     Boolean? @default(false)
  jsonld_how_to_json       String?
  jsonld_enable_breadcrumb Boolean? @default(true)
  jsonld_override_auto     Boolean? @default(false)
  info_pros                String?
  info_cons                String?
  og_title                 String?
  og_desc                  String?
  og_image                 String?
  twitter_card             String?
  json_schema              String?
  fast_filters             String?
  content                  String?
  show_awards              Boolean? @default(false)
  awards                   String?
  footer_company_name      String?  @default("SlotQuest Inc.")
  footer_description       String?  @default("The ultimate catalog for slot enthusiasts. Explore thousands of games, analyze mechanics, and find your next favorite slot with our advanced data-driven platform.")
  footer_facebook          String?  @default("https://facebook.com/slotquest")
  footer_twitter           String?  @default("https://twitter.com/slotquest")
  footer_instagram         String?  @default("https://instagram.com/slotquest")
  footer_telegram          String?  @default("https://t.me/slotquest")
  created_at               DateTime @default(now())
  updated_at               DateTime @updatedAt
  localizations            Json?
  global_affiliate_link    String?
}

model blogs {
  id               String    @id @default(cuid())
  slug             String    @unique
  title            String
  content_markdown String?
  author_name      String?   @default("SlotQuest Team")
  author_avatar    String?
  published_at     DateTime? @default(now())
  updated_at       DateTime? @updatedAt
  is_published     Boolean   @default(true)
  tags             String?
  seo_title        String?
  seo_desc         String?
  seo_keywords     String?
  localizations    Json?
  jsonld_article   Boolean   @default(true)
  category         String?
  cover_image_url  String?
  excerpt          String?
  is_featured      Boolean   @default(false)
  reading_time     Int?      @default(5)

  @@index([is_published])
  @@index([slug])
  @@index([category])
  @@index([published_at(sort: Desc)])
  @@index([is_featured])
}

model slot_reviews {
  id            String   @id @default(cuid())
  slot_id       String
  author_name   String
  author_avatar String?
  rating        Decimal
  text          String
  likes         Int      @default(0)
  language      String   @default("en")
  is_verified   Boolean  @default(true)
  created_at    DateTime @default(now())
  slots         slots    @relation(fields: [slot_id], references: [id], onDelete: Cascade)

  @@index([slot_id])
  @@index([language])
}

model glossary {
  id                   String   @id @default(cuid())
  term                 String   @unique
  slug                 String   @unique
  brief_definition     String
  detailed_explanation String?
  related_terms        String?
  seo_title            String?
  seo_desc             String?
  localizations        Json?
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt
  category             String?
  is_published         Boolean  @default(true)
  letter               String?

  @@index([slug])
  @@index([letter])
  @@index([category])
  @@index([is_published])
}

model casinos {
  id               String       @id @default(cuid())
  name             String       @unique
  slug             String       @unique
  logo_url         String?
  website_url      String?
  affiliate_link   String?
  rating           Decimal?     @default(0.0)
  established_year Int?
  owner            String?
  licensing        String?
  languages        String?
  currencies       String?
  deposit_methods  String?
  withdrawal_limit String?
  is_active        Boolean      @default(true)
  created_at       DateTime     @default(now())
  updated_at       DateTime     @updatedAt
  seo_title        String?
  seo_desc         String?
  content_markdown String?
  pros_cons_json   String?
  faq_json         String?
  localizations    Json?
  promotions       promotions[]

  @@index([is_active])
  @@index([rating(sort: Desc)])
}

model promotions {
  id                String    @id @default(cuid())
  casino_id         String
  title             String
  slug              String    @unique
  promo_type        String
  amount            String?
  wager_requirement String?
  promo_code        String?
  affiliate_link    String?
  is_exclusive      Boolean   @default(false)
  is_active         Boolean   @default(true)
  valid_until       DateTime?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt
  seo_title         String?
  seo_desc          String?
  content_markdown  String?
  localizations     Json?
  casinos           casinos   @relation(fields: [casino_id], references: [id], onDelete: Cascade)

  @@index([casino_id])
  @@index([promo_type])
  @@index([is_active])
}

model news {
  id               String    @id @default(cuid())
  title            String
  slug             String    @unique
  content_markdown String?
  image_url        String?
  source_url       String?
  tags             String?
  author_name      String?   @default("SlotQuest NewsBot")
  published_at     DateTime? @default(now())
  updated_at       DateTime  @updatedAt
  is_published     Boolean   @default(true)
  seo_title        String?
  seo_desc         String?
  localizations    Json?

  @@index([is_published])
  @@index([published_at(sort: Desc)])
}

model streamers {
  id             String     @id @default(cuid())
  name           String     @unique
  slug           String     @unique
  platform       String?
  channel_url    String?
  avatar_url     String?
  bio_markdown   String?
  favorite_slots String?
  seo_title      String?
  seo_desc       String?
  localizations  Json?
  created_at     DateTime   @default(now())
  updated_at     DateTime   @updatedAt
  big_wins       big_wins[]

  @@index([platform])
}

model big_wins {
  id          String    @id @default(cuid())
  streamer_id String
  slot_id     String
  multiplier  Decimal?
  win_amount  Decimal?
  currency    String?   @default("USD")
  video_url   String?
  date        DateTime?
  created_at  DateTime  @default(now())
  streamers   streamers @relation(fields: [streamer_id], references: [id], onDelete: Cascade)

  @@index([streamer_id])
  @@index([multiplier(sort: Desc)])
}
