generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model providers {
  id               String    @id
  name             String    @unique
  slug             String    @unique
  description      String?
  logo_url         String?
  website_url      String?
  founded_year     Int?
  country          String?
  is_active        Boolean?  @default(true)
  created_at       DateTime? @default(now())
  updated_at       DateTime? @default(now())
  is_recommended   Boolean?  @default(false)
  content_markdown String?
  faq_json         String?
  jsonld_enabled   Boolean?  @default(true)
  localizations    Json?
  pros_cons_json   String?
  seo_desc         String?
  seo_keywords     String?
  seo_title        String?
  slots            slots[]
}

model slot_categories {
  id               String    @id
  name             String    @unique
  slug             String    @unique
  description      String?
  created_at       DateTime? @default(now())
  is_active        Boolean?  @default(true)
  updated_at       DateTime? @default(now())
  content_markdown String?
  faq_json         String?
  localizations    Json?
  seo_desc         String?
  seo_keywords     String?
  seo_title        String?
  slots            slots[]
}

