  jsonld_faq_json          String?   // JSON string [ { question, answer } ]
  jsonld_enable_review     Boolean?  @default(false)
  jsonld_review_author     String?
  jsonld_review_rating     Decimal?
  jsonld_review_text       String?
  jsonld_enable_how_to     Boolean?  @default(false)
  jsonld_how_to_json       String?   // JSON string [ { name, text, image } ]
  jsonld_enable_breadcrumb Boolean?  @default(true)
  jsonld_override_auto     Boolean?  @default(false) // Custom override toggle

  // SEO Info Pros/Cons (Mirroring slots)
  info_pros           String?      // JSON string of pros
  info_cons           String?      // JSON string of cons

  // Open Graph / Social
  og_title            String?      // Open Graph Title
  og_desc             String?      // Open Graph Description
  og_image            String?      // Open Graph Image URL
  twitter_card        String?      // Twitter Card Type

  // Advanced
  json_schema         String?      // Custom manual JSON-LD Overrides

  fast_filters        String?      // Dynamic JSON array of top sticky filters [{category_id, name, icon}]
  content             String?      // Dynamic JSON array of SEO Text blocks [{title, icon, text}]
  
  // Custom Content Sections
  show_awards         Boolean?     @default(false)
  awards              String?      // JSON string of awards entries

  // Dynamic Footer Settings
  footer_company_name String?      @default("SlotQuest Inc.")
  footer_description  String?      @default("The ultimate catalog for slot enthusiasts. Explore thousands of games, analyze mechanics, and find your next favorite slot with our advanced data-driven platform.")
  footer_facebook     String?      @default("https://facebook.com/slotquest")
  footer_twitter      String?      @default("https://twitter.com/slotquest")
  footer_instagram    String?      @default("https://instagram.com/slotquest")
  footer_telegram     String?      @default("https://t.me/slotquest")

  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt
}
